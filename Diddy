

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local Library = {}

local THEME = {
	Background = Color3.fromRGB(20,20,20),
	Panel = Color3.fromRGB(18, 12, 25), -- deep purple-black
	Accent = Color3.fromRGB(140, 80, 255), -- purple
	Text = Color3.fromRGB(235,235,235),
	Subtext = Color3.fromRGB(170,170,170),
}

local function new(class, props)
	local obj = Instance.new(class)
	if props then
		for k,v in pairs(props) do
			if k == "Parent" then obj.Parent = v else obj[k] = v end
		end
	end
	return obj
end

local function makeShadow(parent)
	local shadow = new("ImageLabel",{
		Name = "_Shadow",
		Parent = parent,
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1,1),
		Position = UDim2.fromScale(0,0),
		ZIndex = 0,
		Image = "rbxassetid://6014261993", -- soft shadow image
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(10,10,118,118),
		ImageTransparency = 0.85,
	})
	return shadow
end

local function makeRound(parent, radius)
	local uic = new("UICorner", {Parent = parent})
	if radius then uic.CornerRadius = radius end
	return uic
end

local function makeGradient(inst, color)
	local g = new("UIGradient", {Parent = inst})
	g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, color:lerp(Color3.new(),0.15)), ColorSequenceKeypoint.new(1, color)})
	g.Rotation = 270
	return g
end

local function dragify(frame, dragHandle)
	dragHandle = dragHandle or frame
	local dragging = false
	local dragInput, dragStart, startPos
	local UserInputService = game:GetService("UserInputService")

	local function update(input)
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end

	dragHandle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)

	dragHandle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)
end

-- CreateWindow: returns window object with :AddTab(name)
function Library:CreateWindow(title)
	local player = Players.LocalPlayer
	local guiParent = player and player:FindFirstChild("PlayerGui") or game:GetService("CoreGui")

	local screen = new("ScreenGui", {Name = "PurpleUI", Parent = guiParent, ResetOnSpawn = false})

	local main = new("Frame", {
		Name = "Window",
		Parent = screen,
		BackgroundColor3 = THEME.Panel,
		Size = UDim2.new(0, 360, 0, 520),
		Position = UDim2.new(0.5, -180, 0.3, -260),
		ZIndex = 2,
	})
	makeRound(main, UDim.new(0,8))
	makeShadow(main)

	local header = new("Frame", {Parent = main, BackgroundColor3 = THEME.Panel, Size = UDim2.new(1,0,0,46)})
	header.ZIndex = 3
	makeRound(header, UDim.new(0,8))

	local titleLabel = new("TextLabel", {
		Parent = header,
		BackgroundTransparency = 1,
		Position = UDim2.new(0,12,0,6),
		Size = UDim2.new(1,-24,1,-12),
		Text = title or "Window",
		TextColor3 = THEME.Text,
		Font = Enum.Font.GothamBold,
		TextSize = 20,
		TextXAlignment = Enum.TextXAlignment.Left,
	})

	local minBtn = new("TextButton", {
		Parent = header,
		BackgroundTransparency = 1,
		Size = UDim2.new(0,36,0,36),
		Position = UDim2.new(1,-44,0,6),
		Text = "-",
		TextColor3 = THEME.Subtext,
		Font = Enum.Font.GothamBold,
		TextSize = 24,
	})

	local container = new("Frame", {Parent = main, BackgroundTransparency = 1, Position = UDim2.new(0,0,0,46), Size = UDim2.new(1,0,1,-46)})

	-- left tabs column
	local tabsColumn = new("Frame", {Parent = container, BackgroundColor3 = THEME.Background, Size = UDim2.new(0,110,1,0)})
	makeRound(tabsColumn, UDim.new(0,6))
	local tabsList = new("UIListLayout", {Parent = tabsColumn, Padding = UDim.new(0,6), FillDirection = Enum.FillDirection.Vertical, SortOrder = Enum.SortOrder.LayoutOrder})
	tabsList.Padding = UDim.new(0,8)

	-- content area
	local content = new("Frame", {Parent = container, BackgroundColor3 = THEME.Background, Position = UDim2.new(0,110,0,0), Size = UDim2.new(1,-110,1,0)})
	makeRound(content, UDim.new(0,6))

	local pages = {}

	local window = {}

	-- minimize behaviour
	local minimized = false
	minBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		if minimized then
			TweenService:Create(main, TweenInfo.new(0.25), {Size = UDim2.new(0,360,0,46)}):Play()
			for _,v in pairs(content:GetChildren()) do v.Visible = false end
		else
			TweenService:Create(main, TweenInfo.new(0.25), {Size = UDim2.new(0,360,0,520)}):Play()
			for _,v in pairs(content:GetChildren()) do v.Visible = true end
		end
	end)

	dragify(main, header)

	function window:AddTab(name)
		local tabButton = new("TextButton", {
			Parent = tabsColumn,
			Text = name,
			Size = UDim2.new(1,-12,0,40),
			BackgroundColor3 = Color3.fromRGB(28,28,35),
			TextColor3 = THEME.Text,
			Font = Enum.Font.GothamMedium,
			TextSize = 14,
		})
		makeRound(tabButton, UDim.new(0,6))
		local indicator = new("Frame", {Parent = tabButton, BackgroundColor3 = THEME.Accent, Size = UDim2.new(0,4,1,0), Position = UDim2.new(0,0,0,0), Visible = false})

		local page = new("ScrollingFrame", {
			Parent = content,
			BackgroundTransparency = 1,
			Size = UDim2.new(1,0,1,0),
			ScrollBarThickness = 6,
			Visible = false,
		})
		local layout = new("UIListLayout", {Parent = page, Padding = UDim.new(0,8), SortOrder = Enum.SortOrder.LayoutOrder})
		layout.Padding = UDim.new(0,12)
		page.CanvasSize = UDim2.new(0,0,0,0)

		pages[name] = page

		tabButton.MouseButton1Click:Connect(function()
			for k,p in pairs(pages) do p.Visible = false end
			for _,btn in pairs(tabsColumn:GetChildren()) do if btn:IsA("TextButton") then for _,c in pairs(btn:GetChildren()) do if c:IsA("Frame") then c.Visible = false end end end end
			page.Visible = true
			indicator.Visible = true
		end)

		local tabObj = {}

		function tabObj:AddSection(title)
			local section = new("Frame", {Parent = page, BackgroundColor3 = Color3.fromRGB(25,25,30), Size = UDim2.new(1,-18,0,120)})
			makeRound(section, UDim.new(0,6))
			local secTitle = new("TextLabel", {Parent = section, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,8), Size = UDim2.new(1,-24,0,20), Text = title, TextColor3 = THEME.Text, Font = Enum.Font.GothamBold, TextSize = 15, TextXAlignment = Enum.TextXAlignment.Left})

			local contentArea = new("Frame", {Parent = section, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,36), Size = UDim2.new(1,-24,1,-44)})
			local list = new("UIListLayout", {Parent = contentArea, SortOrder = Enum.SortOrder.LayoutOrder})
			list.Padding = UDim.new(0,8)

			local sectionObj = {}

			function sectionObj:AddButton(text, cb)
				local btn = new("TextButton", {Parent = contentArea, BackgroundColor3 = THEME.Accent, Text = text, TextColor3 = Color3.new(1,1,1), Font = Enum.Font.GothamBold, TextSize = 14, Size = UDim2.new(1,0,0,36)})
				makeRound(btn, UDim.new(0,6))
				btn.MouseButton1Click:Connect(function() pcall(function() cb() end) end)
				return btn
			end

			function sectionObj:AddLabel(text)
				local lbl = new("TextLabel", {Parent = contentArea, BackgroundTransparency = 1, Text = text, TextColor3 = THEME.Text, Font = Enum.Font.Gotham, TextSize = 14, Size = UDim2.new(1,0,0,20), TextXAlignment = Enum.TextXAlignment.Left})
				return lbl
			end

			function sectionObj:AddTextBox(placeholder, cb)
				local tb = new("TextBox", {Parent = contentArea, BackgroundColor3 = Color3.fromRGB(40,40,45), Text = "", PlaceholderText = placeholder or "...", TextColor3 = THEME.Text, Font = Enum.Font.Gotham, TextSize = 14, Size = UDim2.new(1,0,0,30)})
				makeRound(tb, UDim.new(0,6))
				tb.FocusLost:Connect(function(enter)
					if enter and cb then pcall(function() cb(tb.Text) end) end
				end)
				return tb
			end

			function sectionObj:AddToggle(text, default, cb)
				local holder = new("Frame", {Parent = contentArea, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,30)})
				local lbl = new("TextLabel", {Parent = holder, BackgroundTransparency = 1, Text = text, TextColor3 = THEME.Text, Font = Enum.Font.Gotham, TextSize = 14, Size = UDim2.new(1,-50,1,0), Position = UDim2.new(0,0,0,0), TextXAlignment = Enum.TextXAlignment.Left})
				local toggle = new("TextButton", {Parent = holder, BackgroundColor3 = Color3.fromRGB(45,45,50), Size = UDim2.new(0,28,0,18), Position = UDim2.new(1,-36,0,6), Text = "", AutoButtonColor = false})
				makeRound(toggle, UDim.new(0,8))
				local knob = new("Frame", {Parent = toggle, BackgroundColor3 = Color3.fromRGB(220,220,220), Size = UDim2.new(0,10,0,10), Position = UDim2.new(0,4,0,4)})
				makeRound(knob, UDim.new(0,6))
				local state = default and true or false
				local function update()
					if state then
						TweenService:Create(toggle, TweenInfo.new(0.18), {BackgroundColor3 = THEME.Accent}):Play()
						TweenService:Create(knob, TweenInfo.new(0.18), {Position = UDim2.new(1,-14,0,4), BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
					else
						TweenService:Create(toggle, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(45,45,50)}):Play()
						TweenService:Create(knob, TweenInfo.new(0.18), {Position = UDim2.new(0,4,0,4), BackgroundColor3 = Color3.fromRGB(220,220,220)}):Play()
					end
				end
				toggle.MouseButton1Click:Connect(function()
					state = not state
					update()
					if cb then pcall(function() cb(state) end) end
				end)
				update()
				return holder
			end

			function sectionObj:AddSlider(text, min, max, default, cb)
				local holder = new("Frame", {Parent = contentArea, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,44)})
				local lbl = new("TextLabel", {Parent = holder, BackgroundTransparency = 1, Text = text, TextColor3 = THEME.Text, Font = Enum.Font.Gotham, TextSize = 14, Size = UDim2.new(1,-60,0,18), Position = UDim2.new(0,0,0,0), TextXAlignment = Enum.TextXAlignment.Left})
				local valLbl = new("TextLabel", {Parent = holder, BackgroundTransparency = 1, Text = tostring(default or min), TextColor3 = THEME.Subtext, Font = Enum.Font.Gotham, TextSize = 14, Size = UDim2.new(0,48,0,18), Position = UDim2.new(1,-48,0,0)})
				local sliderBg = new("Frame", {Parent = holder, BackgroundColor3 = Color3.fromRGB(40,40,45), Size = UDim2.new(1,-12,0,10), Position = UDim2.new(0,6,0,24)})
				makeRound(sliderBg, UDim.new(0,6))
				local sliderFill = new("Frame", {Parent = sliderBg, BackgroundColor3 = THEME.Accent, Size = UDim2.new(0,0,1,0)})
				makeRound(sliderFill, UDim.new(0,6))

				local min = min or 0; local max = max or 100; local cur = default or min
				local dragging = false
				sliderBg.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = true
					end
				end)
				sliderBg.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
				end)
				sliderBg.InputChanged:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
						local rel = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0,1)
						cur = math.floor((min + (max-min) * rel) * 100)/100
						sliderFill.Size = UDim2.new(rel,0,1,0)
						valLbl.Text = tostring(cur)
						if cb then pcall(function() cb(cur) end) end
					end
				end)
				sliderBg.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						local rel = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0,1)
						cur = math.floor((min + (max-min) * rel) * 100)/100
						sliderFill.Size = UDim2.new(rel,0,1,0)
						valLbl.Text = tostring(cur)
						if cb then pcall(function() cb(cur) end) end
					end
				end)
				-- init
				local initRel = (cur - min)/(max-min + 1e-6)
				sliderFill.Size = UDim2.new(initRel,0,1,0)
				valLbl.Text = tostring(cur)
				return holder
			end

			function sectionObj:AddCog(cb)
				local btn = new("ImageButton", {Parent = contentArea, BackgroundTransparency = 1, Image = "rbxassetid://3926305904", Size = UDim2.new(0,28,0,28)})
				btn.ImageColor3 = THEME.Subtext
				btn.MouseButton1Click:Connect(function()
					if cb then pcall(function() cb() end) end
				end)
				return btn
			end

			return sectionObj
		end

		return tabObj
	end

	-- open first tab automatically helper
	function window:Show()
		-- show first tab if exists
		for k,v in pairs(pages) do
			v.Visible = true
			break
		end
	end

	function window:Destroy()
		screen:Destroy()
	end

	return window
end

return Library
